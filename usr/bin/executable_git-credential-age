#!/usr/bin/env sh
#
# git credential helper that decrypts a GitLab PAT from an age-encrypted file.
#
# Usage: configure git with:
# [credential]
#   helper = age

# Only handle "get" — ignore store/erase
if [ "$1" != "get" ]; then exit 0; fi

# Read context from stdin (git sends protocol=, host=, etc.)
protocol=""
host=""
while IFS= read -r line && [ -n "$line" ]; do
  case "$line" in
  protocol=*) protocol="${line#protocol=}" ;;
  host=*) host="${line#host=}" ;;
  esac
done

token=$(secret GIT_PAT)
if [ -z "$token" ]; then
  echo "git-credential-age: failed to decrypt token from $AGE_SECRETS" >&2
  exit 1
fi

echo "protocol=$protocol"
echo "host=$host"
echo "username=oauth2"
echo "password=$token"
