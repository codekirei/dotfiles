#!/usr/bin/env sh

set -eu

VM_NAME=devbox
WORKDIR=/home/kirei

## TODO
# - ensure limactl exists

usage() {
  cat <<'EOF'
Usage:
  devbox <command> [args...]

Commands:
  up                Spin up the vm.
  down              Shut down the vm.
  shell             Open a shell in the vm.
  status            Show status of vm.
  config            Edit vm config.
  reboot            Power cycles vm.
  run <cmd...>      Run an arbitrary command in the vm.
  inject            Inject a file from host path to vm path.
  extract           Extract a file from vm path to host path.
  create            Creates vm.
  destroy           Destroys vm.
  help              Show this help.

Examples:
  devbox start
  devbox run echo hello
EOF
}

# Need at least one argument
[ $# -ge 1 ] || {
  usage
  exit 2
}

cmd=$1
shift

case "$cmd" in
up)
  limactl start $VM_NAME
  ;;

down)
  limactl stop $VM_NAME
  ;;

shell)
  limactl shell --workdir $WORKDIR $VM_NAME
  ;;

status)
  limactl list
  ;;

config)
  limactl edit $VM_NAME
  ;;

reboot)
  limactl restart $VM_NAME
  ;;

run)
  [ $# -ge 1 ] || {
    echo "nothing to run" >&2
    exit 2
  }
  limactl shell --workdir $WORKDIR $VM_NAME -- "$@"
  ;;

inject)
  limactl copy "$1" "$VM_NAME:$2"
  ;;

extract)
  limactl copy "$VM_NAME:$1" "$2"
  ;;

create)
  limactl create -y --name=$VM_NAME ~/.config/devbox/lima.yaml
  rm ~/.lima/"$VM_NAME"/lima.yaml
  ln -s ~/.config/devbox/lima.yaml ~/.lima/"$VM_NAME"/lima.yaml
  ;;

destroy)
  limactl stop -f $VM_NAME
  rm -rf ~/.lima/"$VM_NAME"
  ;;

help | -h | --help)
  usage
  ;;

*)
  echo "Unknown command: $cmd" >&2
  usage >&2
  exit 2
  ;;
esac
