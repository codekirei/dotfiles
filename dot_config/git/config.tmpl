[init]
	defaultBranch = main
[user]
	name = Jacob Blakely
	email = {{ .git.email | quote }}
	signingkey = {{ .git.signingkey }}
[credential]
	helper = age
[credential "https://github.com"]
	username = codekirei
[diff "lockb"]
	textconv = bun
	binary = true
[pull]
	rebase = true
[push]
	autoSetupRemote = true
[core]
	pager = delta
	excludesFile = ~/.config/git/ignore
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	side-by-side = true
[merge]
	conflictStyle = zdiff3
[gpg]
	format = ssh
[commit]
	gpgsign = true
[tag]
	gpgSign = true

; vim: ft=gitconfig
